# ─────────────────────────────────────────────────────────────
#  AROCO Platform — environment variables (TEMPLATE)
#  Copy to `.env.local` and fill in. NEVER put real keys here.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for invitation redirect links). e.g. https://aroco.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — project URL and keys (you create the project and paste these).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — AI assistant (server-only). Read the recommended model from
# https://docs.claude.com/en/api/overview and set it here.
ANTHROPIC_API_KEY=
# Default claude-opus-4-8. Set claude-sonnet-4-6 to cut cost ~5x for the assistant.
ANTHROPIC_MODEL=claude-opus-4-8

# Email (optional — Resend). Automations are built but DISABLED until set.
RESEND_API_KEY=

# WhatsApp (optional — Twilio or WhatsApp Business). DISABLED until set.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# WHATSAPP_FROM=

# Feature flags for the disabled comms automations.
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false

# Inventory sync (Vercel Cron → /api/cron/sync-inventory).
# Shared secret that protects the cron endpoint. Vercel sends it automatically
# as `Authorization: Bearer <CRON_SECRET>`. Use a long random string.
CRON_SECRET=
# Optional override. Defaults to the AROCO inventory sheet (tab gid=826514579)
# published as CSV. Must stay shared as "anyone with the link can view".
# INVENTORY_SHEET_CSV_URL=
# Optional override. Defaults to the AROCO prices sheet (tab gid=1305299793).
# Must stay shared as "anyone with the link can view".
# PRICES_SHEET_CSV_URL=
